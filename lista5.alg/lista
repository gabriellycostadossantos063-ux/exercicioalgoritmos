//---------------exercicio6------------/
algoritmo "futebol"

var
  idade, contMenor18, contJogadores, contPeso80:
  inteiro 
  peso, altura, somaIdade, somaAltura:real

inicio
 contMenor18 <- 0
 contJogadores <- 0
 contPeso80 <- 0
 somaIdade <- 0
 somaAltura <- 0

 leia(idade)
  enquanto idade <> 0 faca
  leia(peso)
  leia(altura)

  contJogadores <- contJogadores + 1
  somaIdade <- somaIdade + somaIdade
  somaAltura <- somaAltura + altura

  se idade < 18 entao
  contMenor18 <- contMenor18 +1
  fimse

  leia(idade)
  fimenquanto

  escreva("menores de 18: ", contMenor18)
  escreva("media idade: ", somaIdade/contJogadores)
  escreva("media altura: ", somaAltura/contJogadores)
  escreva("mais de 80kg: ", contPeso80)


fimalgoritmo


