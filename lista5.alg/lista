algoritmo "multiplos"

var

   i: inteiro

inicio

   escreval("--- Múltiplos de 3 (3 a 30) ---")

   para i de 3 ate 30 passo 3 faca

      escreva(i, " ")

   fimpara

fimalgoritmo

