algoritmo "conceito_alunos"

var
  i: inteiro
  nota: real

inicio

  para i de 1 ate 10 faca
  leia(nota)

   se nota >= 0 e nota <= 2.9 entao
      escreval("E")
      senao se nota <= 4.9 entao
      escreva("D")
      senao se nota <= 6.9 entao
      escreva("C")
      senao se nota <= 8.9 entao
      escreva("B")
      senao
      escreva("A")
      fimse
      fimse
      fimse
      fimse
  fimpara
fimalgoritmo


