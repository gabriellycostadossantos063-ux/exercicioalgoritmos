algoritmo "verificar numero"

var
   numero:real

inicio
   escreva("digite um numero: ")
   leia(numero)

   se numero > 0 entao
    escreval("o numero é positivo")
    senao
    se numero < 0 entao
    escreval("o numero é negativo")
    senao
    escreval("o numero é zero")
    fimse
    fimse


fimalgoritmo
