//-------exercicio1------//
algoritmo "maiores_idade"

var

   idade, i, cont: inteiro
 
inicio

   cont <- 0
 
   para i de 1 ate 10 faca

      escreva("Digite a idade: ")

      leia(idade)
 
      se idade >= 18 entao

         cont <- cont + 1

      fimse

   fimpara
 
   escreva("Quantidade de maiores de idade: ", cont)

fimalgoritmo
 

