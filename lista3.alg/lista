algoritmo "tabela_temperatura"
var
   f: inteiro
   c: real
 
inicio
   para f de 50 ate 65 faca
      c <- (5/9) * (f - 32)
      escreva("F: ", f, " -> C: ", c)
   fimpara
fimalgoritmo


//-----------exercicio6-------//
algoritmo "seq_a"
 
var

   i: inteiro

   soma: real
 
inicio

   i <- 1

   soma <- 0
 
   enquanto i <= 100 faca

      soma <- soma + (i / (i * 4))

      i <- i + 1

   fimenquanto
 
   escreval("Resultado: ", soma)
 
fimalgoritmo
 
