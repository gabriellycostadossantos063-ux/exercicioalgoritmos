algoritmo "eleicao"

var

   voto, i: inteiro

   c1, c2, c3, c4, nulo, branco: inteiro

 inicio

   c1<-0 c2<-0 c3<-0 c4<-0

   nulo<-0 branco<-0
 
   para i de 1 ate 100 faca

      leia(voto)
 
      escolha voto

         Caso 1

            c1 <- c1 + 1

         Caso 2

            c2 <- c2 + 1

         Caso 3

            c3 <- c3 + 1

         Caso 4

            c4 <- c4 + 1

         Caso 5

            nulo <- nulo + 1

         Caso 6

            branco <- branco + 1

      fimescolha

   fimpara
 
   escreva("Candidato 1: ", c1)

   escreva("Candidato 2: ", c2)

   escreva("Candidato 3: ", c3)

   escreva("Candidato 4: ", c4)

   escreva("Nulos: ", nulo)

   escreva("Brancos: ", branco)

fimalgoritmo
 

